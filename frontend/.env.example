# Copy this file to .env and fill in your values.
# Variables prefixed with PUBLIC_ are exposed to the browser.

# === Required: Infrastructure ===
# Workers API URL (use localhost for local dev, your workers URL for production)
PUBLIC_API_URL=http://localhost:8787

# Admin token (must match the ADMIN_TOKEN secret set on your Workers API)
PUBLIC_ADMIN_TOKEN=change-me-to-a-strong-token

# === Site Branding ===
PUBLIC_SITE_NAME=My Tech Blog
PUBLIC_SITE_DESCRIPTION=A personal tech knowledge base
PUBLIC_SITE_EMOJI=🤖
PUBLIC_HERO_TITLE=My Tech Blog
PUBLIC_HERO_SUBTITLE=Ideas, notes, and documentation in one place.

# === Author / Social (leave blank to hide) ===
PUBLIC_AUTHOR=Your Name
PUBLIC_AUTHOR_GITHUB=https://github.com/yourusername
PUBLIC_AUTHOR_TWITTER=https://twitter.com/yourusername
